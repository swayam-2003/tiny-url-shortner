# =============================================================================
# Production environment variables (Fly.io secrets + Vercel / build args)
# Copy to Fly:  fly secrets set KEY=value
# Never commit real secrets to git.
# =============================================================================

# --- PostgreSQL (Neon — use POOLED connection string) ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/shortner?sslmode=require

# --- Redis (Upstash — use TLS URL) ---
REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6379

# --- Public URL of your API (used in generated short links) ---
BASE_URL=https://your-app.fly.dev

# --- CORS: comma-separated frontend origins (split-domain deploy only) ---
# Skip if using unified Fly deploy (UI + API same origin).
ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Core ---
NODE_ENV=production
PORT=3001
SERVER_ID=fly-prod-1

# --- Unified domain: serve React from Express (auto-detected if public/ exists) ---
SERVE_STATIC=true

# --- Optional tuning ---
REDIS_TTL_SECONDS=86400
DEFAULT_EXPIRY_DAYS=1825

# --- Vercel only (build-time, split-domain deploy) ---
VITE_API_URL=https://your-app.fly.dev

# --- Docker build arg (unified Fly deploy — leave empty for same-origin) ---
# VITE_API_URL=
