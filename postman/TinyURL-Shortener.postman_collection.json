{
  "info": {
    "name": "TinyURL Shortener API",
    "description": "Enterprise URL shortener — shorten, redirect (301), analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "shortCode", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "URL Management",
      "item": [
        {
          "name": "Shorten URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.shortCode) {",
                  "  pm.collectionVariables.set('shortCode', res.data.shortCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"longUrl\": \"https://www.geeksforgeeks.org/system-design-url-shortening-service/\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/urls"
          }
        },
        {
          "name": "Shorten with Custom Alias",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"longUrl\": \"https://example.com/docs\",\n  \"customAlias\": \"my-docs\",\n  \"expiresInDays\": 365\n}"
            },
            "url": "{{baseUrl}}/api/v1/urls"
          }
        },
        {
          "name": "Get URL Metadata",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/urls/{{shortCode}}"
          }
        },
        {
          "name": "Deactivate URL",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/urls/{{shortCode}}"
          }
        },
        {
          "name": "Invalid URL (error)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"longUrl\": \"not-a-valid-url\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/urls"
          }
        }
      ]
    },
    {
      "name": "Redirect",
      "item": [
        {
          "name": "301 Redirect",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/{{shortCode}}"
          }
        },
        {
          "name": "Not Found (error)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/nonexistent99"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Analytics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/urls/{{shortCode}}/analytics"
          }
        }
      ]
    }
  ]
}
