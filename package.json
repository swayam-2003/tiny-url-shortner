{
  "name": "tiny-url-shortner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "vite",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build",
    "build:backend": "npm run build --prefix backend",
    "migrate": "npm run migrate --prefix backend",
    "benchmark": "npm run benchmark --prefix backend",
    "benchmark:full": "npm run benchmark:full --prefix backend",
    "benchmark:redis-down": "npm run benchmark --prefix backend -- --redis-down",
    "benchmark:k6": "docker run --rm -v \"%cd%/benchmark:/scripts\" -e K6_BASE_URL=http://host.docker.internal:3001 grafana/k6 run /scripts/k6-redirect.js",
    "benchmark:k6:mixed": "docker run --rm -v \"%cd%/benchmark:/scripts\" -e K6_BASE_URL=http://host.docker.internal:3001 -e K6_VUS=100 grafana/k6 run /scripts/k6-mixed.js",
    "benchmark:k6:nginx": "docker run --rm -v \"%cd%/benchmark:/scripts\" -e K6_BASE_URL=http://host.docker.internal grafana/k6 run /scripts/k6-nginx.js",
    "benchmark:k6:stress": "docker run --rm -v \"%cd%/benchmark:/scripts\" -e K6_BASE_URL=http://host.docker.internal -e K6_VUS=1000 -e K6_DURATION=60s grafana/k6 run /scripts/k6-stress.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
