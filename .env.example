# Use local PostgreSQL (port 5432):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/shortner

# Or use Docker PostgreSQL (port 5433):
DATABASE_URL=postgresql://postgres:password@localhost:5433/shortner
REDIS_URL=redis://localhost:6379
PORT=3001
BASE_URL=http://localhost:3001
DEFAULT_EXPIRY_DAYS=1825
REDIS_TTL_SECONDS=86400
NODE_ENV=development
VITE_API_URL=http://localhost:3001

# Production: see .env.production.example and DEPLOY.md
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
# SERVE_STATIC=true
BENCHMARK_URL=http://localhost:3001
BENCHMARK_ITERATIONS=50
